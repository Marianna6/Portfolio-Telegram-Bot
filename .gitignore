# Build Artifacts
# Exclude temporary build files and binaries
[Bb]in/
[Oo]bj/

# Visual Studio Settings
# Exclude user-specific configuration and cache
.vs/
*.user
*.suo

# Database
# Exclude local database files to protect data
*.db
*.db-shm
*.db-wal

# Logs
*.log

# Configuration and Secrets
# Exclude files containing sensitive tokens and local test settings
.runsettings
launchSettings.json
.env